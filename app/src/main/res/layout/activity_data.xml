<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ProgressBar
        android:id="@+id/data_pb"
        android:layout_width="@dimen/_45sdp"
        android:layout_height="@dimen/_48sdp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginEnd="366sp"
        android:layout_marginBottom="@dimen/_48sdp"
        android:indeterminateTint="@color/teal_700"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <Toolbar
            android:id="@+id/main_toolbar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <EditText
            android:id="@+id/data_customer_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_10sdp"
            android:layout_marginTop="@dimen/_10sdp"
            android:layout_marginEnd="@dimen/_10sdp"
            android:hint="Name"
            android:padding="@dimen/_16sdp"

            android:textSize="@dimen/_20ssp" />

        <EditText
            android:id="@+id/data_customer_number"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/_10sdp"
            android:hint="Number"
            android:inputType="number"
            android:padding="16dp"
            android:textSize="@dimen/_20ssp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/data_customer_area"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                android:layout_weight="1"
                android:hint="Area"
                android:inputType="number"
                android:padding="16dp"
                android:textSize="@dimen/_20ssp" />


            <EditText
                android:id="@+id/data_seller_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="10dp"
                android:layout_weight="1"
                android:hint="Seller Name"
                android:padding="16dp"
                android:textSize="@dimen/_20ssp" />

        </LinearLayout>

        <EditText
            android:id="@+id/data_customer_plant"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/_10sdp"
            android:layout_marginEnd="@dimen/_10sdp"
            android:layout_marginBottom="@dimen/_10sdp"
            android:hint="plant type"
            android:padding="16dp"
            android:textSize="@dimen/_20ssp" />

        <Button
            android:id="@+id/data_btn_save_data"
            android:layout_width="@dimen/_200sdp"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:backgroundTint="#4CAF50"
            android:padding="8dp"
            android:text="Save Data" />

    </LinearLayout>
</RelativeLayout>
